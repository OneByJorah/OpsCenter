# Agent Mission Control — Environment Configuration
#
# Copy this file to .env and edit as needed.

# --- Server ---
PORT=51763
BIND=0.0.0.0

# --- Security ---
# Set an API key to protect write endpoints (board tasks, content editing)
MISSION_CONTROL_API_KEY=

# --- Hermes Home ---
# Path to the Hermes state directory on the host machine
# This is mounted into the container for agent-logs and state access
HERMES_HOME=~/.hermes

# --- Content Directory ---
# Where markdown content files are stored (relative to container)
MISSION_CONTROL_CONTENT_DIR=/app/content
